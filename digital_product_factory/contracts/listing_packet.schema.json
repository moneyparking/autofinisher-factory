{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/listing_packet.schema.json",
  "title": "Listing Packet (Etsy publish-ready)",
  "type": "object",
  "required": [
    "packet_version",
    "packet_id",
    "product_slug",
    "product_kind",
    "product_family",
    "channel",
    "title",
    "description",
    "tags",
    "category",
    "price_anchor",
    "format_hint",
    "artifacts",
    "source_provenance",
    "digital_product_spec_path",
    "artifact_manifest_path",
    "listing_title",
    "buyer_promise",
    "short_description",
    "long_description",
    "feature_bullets",
    "benefit_bullets",
    "deliverable_files",
    "preview_files",
    "manual_steps",
    "review_checks",
    "publish_status",
    "description_intro",
    "description_whats_included",
    "description_how_it_works",
    "description_what_youll_get",
    "description_terms",
    "description_compatibility",
    "seo_aeo",
    "listing_image_plan",
    "listing_image_paths",
    "market_readiness"
  ],
  "properties": {
    "packet_version": {"type": "string"},
    "packet_id": {"type": "string"},
    "product_slug": {"type": "string", "minLength": 1},
    "product_kind": {"type": "string", "enum": ["planner", "checklist", "spreadsheet", "notion_companion"]},
    "product_family": {"type": "string", "minLength": 1},
    "channel": {"type": "string", "const": "etsy"},
    "type": {"type": "string", "const": "download"},
    "is_digital": {"type": "boolean"},
    "digital_product_spec_path": {"type": "string", "minLength": 1},
    "artifact_manifest_path": {"type": "string", "minLength": 1},
    "validated_niche_path": {"type": ["string", "null"]},
    "winner_path": {"type": ["string", "null"]},
    "sku_task_path": {"type": ["string", "null"]},
    "listing_title": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "buyer_promise": {"type": "string", "minLength": 1},
    "short_description": {"type": "string", "minLength": 1},
    "long_description": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "feature_bullets": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "benefit_bullets": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "primary_keyword": {"type": ["string", "null"]},
    "secondary_keywords": {"type": "array", "items": {"type": "string"}},
    "tags": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 13, "maxItems": 13},
    "category": {"type": "string", "minLength": 1},
    "price_anchor": {"type": ["number", "integer"], "minimum": 0},
    "format_hint": {"type": "string"},
    "deliverable_files": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "preview_files": {"type": "array", "items": {"type": "string"}},
    "thumbnail_files": {"type": "array", "items": {"type": "string"}},
    "license_note": {"type": ["string", "null"]},
    "license_hint": {"type": ["string", "null"]},
    "what_is_included": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "artifacts": {
      "type": "object",
      "required": [
        "deliverable_path",
        "preview_path",
        "master_path",
        "mockup_path",
        "seo_path",
        "source_csv_path",
        "rendered_listing_html_path",
        "listing_image_plan_path"
      ],
      "properties": {
        "deliverable_path": {"type": "string", "minLength": 1},
        "preview_path": {"type": "string", "minLength": 1},
        "master_path": {"type": "string", "minLength": 1},
        "mockup_path": {"type": "string", "minLength": 1},
        "seo_path": {"type": "string", "minLength": 1},
        "source_csv_path": {"type": "string", "minLength": 1},
        "rendered_listing_html_path": {"type": "string", "minLength": 1},
        "listing_image_plan_path": {"type": "string", "minLength": 1},
        "extra_assets": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "source_provenance": {
      "type": "object",
      "required": ["niche_id", "winner_path", "sku_task_path"],
      "properties": {
        "niche_id": {"type": "string", "minLength": 1},
        "winner_path": {"type": "string"},
        "sku_task_path": {"type": "string"},
        "validated_niche_path": {"type": "string"}
      },
      "additionalProperties": false
    },
    "qa_summary": {
      "type": "object",
      "properties": {
        "checks_passed": {"type": "boolean"},
        "missing_files": {"type": "array", "items": {"type": "string"}},
        "broken_links": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "manual_steps": {"type": "array", "items": {"type": "string"}},
    "review_checks": {"type": "array", "items": {"type": "string"}},
    "publish_status": {"type": "string"},
    "description_intro": {"type": "string", "minLength": 1},
    "description_whats_included": {"type": "string", "minLength": 1},
    "description_how_it_works": {"type": "string", "minLength": 1},
    "description_what_youll_get": {"type": "string", "minLength": 1},
    "description_terms": {"type": "string", "minLength": 1},
    "description_compatibility": {"type": "string", "minLength": 1},
    "photo_sequence_hint": {"type": "string", "minLength": 1},
    "thumbnail_angle": {"type": "string", "minLength": 1},
    "upload_order_hint": {"type": "string", "minLength": 1},
    "seo_aeo": {
      "type": "object",
      "required": ["what_is_it", "who_is_it_for", "what_do_i_get", "how_do_i_use_it", "compatibility"],
      "properties": {
        "what_is_it": {"type": "string", "minLength": 1},
        "who_is_it_for": {"type": "string", "minLength": 1},
        "what_do_i_get": {"type": "string", "minLength": 1},
        "how_do_i_use_it": {"type": "string", "minLength": 1},
        "compatibility": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "listing_image_plan": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["slot", "headline", "purpose", "detail", "asset_hint"],
        "properties": {
          "slot": {"type": "integer", "minimum": 1, "maximum": 10},
          "headline": {"type": "string", "minLength": 1},
          "purpose": {"type": "string", "minLength": 1},
          "detail": {"type": "string", "minLength": 1},
          "asset_hint": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "listing_image_paths": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {"type": "string", "minLength": 1}
    },
    "market_readiness": {
      "type": "object",
      "required": ["buyer_facing_copy", "seo_aeo_complete", "title_readable", "tags_ready", "image_plan_ready"],
      "properties": {
        "buyer_facing_copy": {"type": "boolean"},
        "seo_aeo_complete": {"type": "boolean"},
        "title_readable": {"type": "boolean"},
        "tags_ready": {"type": "boolean"},
        "image_plan_ready": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
